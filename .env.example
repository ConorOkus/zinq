# WebSocket-to-TCP proxy URL for Lightning peer connections.
# Optional — defaults to wss://proxy.zinqq.app if unset.
VITE_WS_PROXY_URL=wss://proxy.zinqq.app

# Esplora API URL override for both LDK and BDK.
# Optional — defaults to /api/esplora (Vercel serverless proxy to Blockstream Enterprise).
# VITE_ESPLORA_URL=https://mempool.space/api

# VSS (Versioned Storage Service) URL for encrypted remote state backup.
# Defaults to /api/vss-proxy (Vercel serverless function).
# In local dev, set to /__vss_proxy/vss so the Vite proxy handles it.
VITE_VSS_URL=/__vss_proxy/vss

# Backend target for the Vite dev proxy (/__vss_proxy -> this URL).
# Only used by the Vite dev server; not shipped to the browser.
# Defaults to http://localhost:8080 if unset.
VSS_PROXY_TARGET=http://localhost:8080

# LSP (Lightning Service Provider) for LSPS2 JIT channels.
# Required — no hardcoded defaults. Set these for your network.
VITE_LSP_NODE_ID=
VITE_LSP_HOST=
VITE_LSP_PORT=9735
# VITE_LSP_TOKEN=
